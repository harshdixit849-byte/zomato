DATABASE_URL=mysql://user:password@host:port/dbname
JWT_SECRET=replace_with_a_long_random_string
PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Razorpay (test mode). Get test keys from the Razorpay Dashboard > Settings
# > API Keys. Leave RAZORPAY_ENABLED=false (or unset) to fall back to
# cash-on-delivery order creation with no payment step.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_your_test_key_secret
RAZORPAY_MODE=test
RAZORPAY_ENABLED=false
